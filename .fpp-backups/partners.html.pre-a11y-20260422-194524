  <script>
    // Partners page opt-in (mirrors index.html footer form, posts source=partners-page so server routes to Partners group)
    (function(){
      const submitEmail = async (email, errorEl) => {
        if (errorEl) { errorEl.textContent=''; errorEl.classList.remove('active'); }
        try {
          const res = await fetch('/.netlify/functions/subscribe', {
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body:JSON.stringify({email:email, source:'partners-page'})
          });
          const data = await res.json().catch(()=>({}));
          if (res.ok && data.success) return true;
          throw new Error(data.error || 'Something went wrong. Please try again.');
        } catch(err){
          if (errorEl){ errorEl.textContent = err.message || 'Something went wrong. Please try again.'; errorEl.classList.add('active'); }
          return false;
        }
      };
      const form = document.getElementById('fpp-partners-form');
      const emailEl = document.getElementById('fpp-partners-email');
      const submit = document.getElementById('fpp-partners-submit');
      const error = document.getElementById('fpp-partners-error');
      const success = document.getElementById('fpp-partners-success');
      if (!submit) return;
      const handle = async () => {
        const email = (emailEl.value || '').trim();
        if (!email) {
          error.textContent = 'Please enter an email address';
          error.classList.add('active');
          emailEl.focus();
          return;
        }
        submit.disabled = true;
        const orig = submit.textContent;
        submit.textContent = 'SENDING...';
        const ok = await submitEmail(email, error);
        submit.disabled = false;
        submit.textContent = orig;
        if (ok) {
          form.classList.add('fpp-form-hidden');
          success.classList.remove('fpp-form-hidden');
        }
      };
      submit.addEventListener('click', handle);
      emailEl.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); handle(); } });
    })();
  </script>

