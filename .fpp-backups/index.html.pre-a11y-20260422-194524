        <div class="flex flex-col gap-3">
          <input type="email" id="fpp-popup-email" class="fpp-optin-input px-4 py-3 rounded-md" placeholder="your@email.com" autocomplete="email" required />
          <button type="button" id="fpp-popup-submit" class="fpp-optin-btn px-6 py-3 rounded-md">SEND ME THE CODE</button>
        </div>
        <p id="fpp-popup-error" class="fpp-error-msg"></p>
        <div class="mt-4 text-center">
          <button type="button" class="fpp-dismiss-link" id="fpp-popup-dismiss">No thanks, I don&rsquo;t want 10% off</button>
        </div>
      </div>
      <div id="fpp-popup-success" class="fpp-form-hidden text-center">
        <p class="fpp-display text-3xl mb-3" style="color:#1c1c1c;">Check your inbox &#10003;</p>
        <p class="text-sm mb-5" style="color:#1c1c1c;">We sent you a confirmation email. Click the link inside and your code is on the way.</p>
        <button type="button" class="fpp-optin-btn px-6 py-3 rounded-md" id="fpp-popup-close-success">GOT IT</button>
      </div>
    </div>
  </div>

