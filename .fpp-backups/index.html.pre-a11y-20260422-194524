  <script>
    function switchTab(tab, btn) {
      document.querySelectorAll('.booking-panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.getElementById('panel-' + tab).classList.add('active');
      btn.classList.add('active');
    }

    // ===== FPP Opt-In (footer form + exit-intent popup) =====
    (function() {
      const POPUP_SESSION_KEY = 'fpp_popup_seen_v1';
      const POPUP_SUPPRESS_KEY = 'fpp_popup_suppressed_v1';

      async function submitEmail(email, source, errorEl) {
        if (errorEl) { errorEl.textContent = ''; errorEl.classList.remove('active'); }
        try {
          const res = await fetch('/.netlify/functions/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email, source: source })
          });
          const data = await res.json().catch(() => ({}));
          if (res.ok && data.success) return true;
          throw new Error(data.error || 'Something went wrong. Please try again.');
        } catch (err) {
          if (errorEl) {
            errorEl.textContent = err.message || 'Something went wrong. Please try again.';
            errorEl.classList.add('active');
          }
          return false;
        }
      }

      // --- Footer form ---
      const footerForm = document.getElementById('fpp-footer-form');
      const footerEmail = document.getElementById('fpp-footer-email');
      const footerSubmit = document.getElementById('fpp-footer-submit');
      const footerError = document.getElementById('fpp-footer-error');
      const footerSuccess = document.getElementById('fpp-footer-success');

      if (footerSubmit) {
        const handleFooterSubmit = async () => {
          const email = (footerEmail.value || '').trim();
          if (!email) {
            footerError.textContent = 'Please enter an email address';
            footerError.classList.add('active');
            footerEmail.focus();
            return;
          }
          footerSubmit.disabled = true;
          const originalText = footerSubmit.textContent;
          footerSubmit.textContent = 'SENDING...';
          const ok = await submitEmail(email, 'footer', footerError);
          footerSubmit.disabled = false;
          footerSubmit.textContent = originalText;
          if (ok) {
            footerForm.classList.add('fpp-form-hidden');
            footerSuccess.classList.remove('fpp-form-hidden');
          }
        };
        footerSubmit.addEventListener('click', handleFooterSubmit);
        footerEmail.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') { e.preventDefault(); handleFooterSubmit(); }
        });
      }

      // --- Exit-intent popup ---
      const popup = document.getElementById('fpp-popup');
      if (!popup) return;

      const popupFormWrap = document.getElementById('fpp-popup-form-wrap');
      const popupEmail = document.getElementById('fpp-popup-email');
      const popupSubmit = document.getElementById('fpp-popup-submit');
      const popupError = document.getElementById('fpp-popup-error');
      const popupSuccess = document.getElementById('fpp-popup-success');
      const popupClose = document.getElementById('fpp-popup-close');
      const popupDismiss = document.getElementById('fpp-popup-dismiss');
      const popupCloseSuccess = document.getElementById('fpp-popup-close-success');

      function showPopup() {
        if (sessionStorage.getItem(POPUP_SESSION_KEY)) return;
        try { if (localStorage.getItem(POPUP_SUPPRESS_KEY)) return; } catch(e) {}
        popup.classList.add('active');
        try { sessionStorage.setItem(POPUP_SESSION_KEY, '1'); } catch(e) {}
        document.body.style.overflow = 'hidden';
      }

      function hidePopup() {
        popup.classList.remove('active');
        document.body.style.overflow = '';
      }

      let exitBound = false;
      function bindExitIntent() {
        if (exitBound) return;
        exitBound = true;
        document.addEventListener('mouseleave', (e) => {
          if (e.clientY <= 10) showPopup();
        });
      }

      // Engagement timer: show after 45s if user hasn't left
      setTimeout(() => showPopup(), 45000);
      // Exit-intent binding after page is warm
      setTimeout(bindExitIntent, 5000);

      popupClose.addEventListener('click', hidePopup);
      popupDismiss.addEventListener('click', () => {
        try { localStorage.setItem(POPUP_SUPPRESS_KEY, '1'); } catch(e) {}
        hidePopup();
      });
      if (popupCloseSuccess) popupCloseSuccess.addEventListener('click', hidePopup);
      popup.addEventListener('click', (e) => { if (e.target === popup) hidePopup(); });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && popup.classList.contains('active')) hidePopup();
      });

      const handlePopupSubmit = async () => {
        const email = (popupEmail.value || '').trim();
        if (!email) {
          popupError.textContent = 'Please enter an email address';
          popupError.classList.add('active');
          popupEmail.focus();
          return;
        }
        popupSubmit.disabled = true;
        const originalText = popupSubmit.textContent;
        popupSubmit.textContent = 'SENDING...';
        const ok = await submitEmail(email, 'popup', popupError);
        popupSubmit.disabled = false;
        popupSubmit.textContent = originalText;
        if (ok) {
          popupFormWrap.classList.add('fpp-form-hidden');
          popupSuccess.classList.remove('fpp-form-hidden');
        }
      };
      popupSubmit.addEventListener('click', handlePopupSubmit);
      popupEmail.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') { e.preventDefault(); handlePopupSubmit(); }
      });
    })();
  </script>
  <!-- EXIT-INTENT POPUP -->
